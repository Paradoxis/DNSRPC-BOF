  msg:"MRLN-SRT - Suspicious MS-DNSP (ADIDNS RPC) LogFilePath+ClearDebugLog coercion request observed 1/2"; 
  flow:to_server; 
  content:"|05 00 00|"; offset:0; depth:3; 
  content:"|02 00 00 00|"; offset:12; depth:4; 
  content:"|05 00|"; offset:22; depth:2; 
  content:"LogFilePath"; distance:0; nocase;  within:400;
  content:"|5c 00 5c 00|"; distance:0; within:50;
  content:"|5c 00|"; distance:0; within:520;
  content:"|5c 00|"; distance:0; within:170;
  flowbits:set,dnsrpc.logfilepath_call;
  flowbits:noalert;
  sid:1000040; rev:1;
)
alert tcp any any -> any any (
