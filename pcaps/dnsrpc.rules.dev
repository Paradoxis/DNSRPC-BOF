# DCERPC header + callid:3 + opnum:5 + "Restart" operation
alert tcp any any -> any any (
  msg:"MRLN-SRT - Suspicious MS-DNSP (ADIDNS RPC) restart request observed"; 
  flow:to_server; 
  content:"|05 00 00|"; offset:0; depth:3; 
  content:"|03 00 00 00|"; offset:12; depth:4; 
  content:"|05 00|"; offset:22; depth:2; 
  content:"Restart"; distance:0; nocase; 
  sid:1000010; rev:1;
)

